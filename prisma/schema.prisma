generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DeliveryStatus {
  pending
  sent
  failed
}

model User {
  id                String         @id @default(cuid())
  telegramUserId    String         @unique @map("telegram_user_id")
  telegramChatId    String         @unique @map("telegram_chat_id")
  telegramUsername  String?        @map("telegram_username")
  telegramFirstName String?        @map("telegram_first_name")
  settings          UserSettings?
  birthdays         Birthday[]
  deliveryLogs      DeliveryLog[]
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  @@map("users")
}

model UserSettings {
  userId                String   @id @map("user_id")
  timezone              String   @default("Europe/Moscow")
  notifyAt              String   @default("09:00") @map("notify_at")
  notificationsEnabled  Boolean  @default(true) @map("notifications_enabled")
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("user_settings")
}

model Birthday {
  id                String        @id @default(cuid())
  userId            String        @map("user_id")
  fullName          String        @map("full_name")
  month             Int
  day               Int
  birthYear         Int?          @map("birth_year")
  notes             String?
  isReminderEnabled Boolean       @default(true) @map("is_reminder_enabled")
  deletedAt         DateTime?     @map("deleted_at")
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveryLogs      DeliveryLog[]
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@map("birthdays")
}

model DeliveryLog {
  id                String         @id @default(cuid())
  userId            String         @map("user_id")
  birthdayId        String         @map("birthday_id")
  notificationType  String         @map("notification_type")
  occurrenceDate    DateTime       @map("occurrence_date") @db.Date
  status            DeliveryStatus @default(pending)
  attemptCount      Int            @default(0) @map("attempt_count")
  lastAttemptAt     DateTime?      @map("last_attempt_at")
  sentAt            DateTime?      @map("sent_at")
  telegramMessageId String?        @map("telegram_message_id")
  errorMessage      String?        @map("error_message")
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthday          Birthday       @relation(fields: [birthdayId], references: [id], onDelete: Cascade)
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  @@unique([userId, birthdayId, notificationType, occurrenceDate])
  @@map("delivery_logs")
}
